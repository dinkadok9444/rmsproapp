rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Booking resit — public read (customer view), upload max 50KB image
    match /booking_resit/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Booking settings (QR images) — public read, upload max 2MB image
    match /booking_settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // POS settings (QR images) — public read, max 2MB image
    match /pos_settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Accessories, inventory, repairs, marketplace products — per-tenant
    match /accessories/{ownerID}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /inventory/{ownerID}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /repairs/{ownerID}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /marketplace_products/{ownerID}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /seller_verification/{ownerID}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 3 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default — DENY. Any new path must be explicitly whitelisted above.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
